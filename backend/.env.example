# .env.example → 복사해서 .env 로 이름 변경 후 키 입력

# NewsAPI - 무료 100req/day (https://newsapi.org 가입)
NEWS_API_KEY=your_newsapi_key_here

# Finnhub - 무료 60req/min (https://finnhub.io 가입)
# 경제 캘린더 실시간 데이터에 사용
FINNHUB_API_KEY=your_finnhub_key_here

# ─── 아래는 선택사항 (없어도 동작) ───────────────────────────────

# 한국투자증권 KIS API (국내 주식 실시간)
# https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
